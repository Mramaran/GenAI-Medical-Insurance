# Blockchain (Sepolia Testnet)
# Free options (no API key needed): https://rpc.ankr.com/eth_sepolia
# Or use Alchemy/Infura with free-tier key for better reliability
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia
WALLET_PRIVATE_KEY=your_sepolia_wallet_private_key
CONTRACT_ADDRESS=your_deployed_contract_address

# Optional: Gemini (for demo mode — faster than local Ollama)
GEMINI_API_KEY=your_gemini_api_key

# Optional: toggle Gemini vs Ollama
USE_GEMINI=false
